# === LLM Configuration ===
# OpenAI-compatible API endpoint (vLLM / TGI / Ollama / OpenAI)
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=your-api-key
LLM_MODEL_ID=qwen3-8b-rl
LLM_TIMEOUT_MS=10000

# Fallback model (larger model for degradation scenarios)
LLM_FALLBACK_BASE_URL=http://localhost:8002/v1
LLM_FALLBACK_MODEL_ID=qwen2.5-72b

# === Redis Configuration ===
REDIS_URL=redis://localhost:6379

# === Data Directories ===
# ECOM_AGENT_HOME defaults to ~/.ecom-agent/ if not set
# ECOM_AGENT_HOME=/data/ecom-agent

# === Server Configuration ===
PORT=3000
NODE_ENV=development

# === Business Parameters (hot-updatable via Admin API) ===
SLIDING_WINDOW_SIZE=10
BADCASE_BATCH_SIZE=50
AB_TRAFFIC_RATIO=0.1
