{
  "name": "ecom-agent",
  "version": "0.1.0",
  "description": "电商客服智能 Agent — 用户特征画像驱动的规格推荐系统",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "cli": "tsx src/presentation/cli/agent-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev\" \"npm run web\"",
    "web": "cd web && npm run dev",
    "web:build": "cd web && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ecommerce",
    "agent",
    "llm",
    "user-profile"
  ],
  "license": "ISC",
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "@opentelemetry/api": "^1.9.1",
    "chromadb": "^3.4.0",
    "cockatiel": "^3.2.1",
    "commander": "^14.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "neverthrow": "^8.1.1",
    "openai": "^4.76.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.0"
  }
}
